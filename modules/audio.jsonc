{
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "scroll-step": 5,
    "format-muted": "贈ｨ",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "format-icons": {
      "headphone": "隥･",
      "headset": "隥･",
      "default": ["隥ｦ", "隥ｧ", "隥ｨ "]
    }
  },
  "pulseaudio/slider": {
    "orientation": "horizontal",
    "interval": 10
  }
}
